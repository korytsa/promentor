{
  "name": "@promentorapp/types",
  "version": "0.1.1",
  "description": "Shared TypeScript types for ProMentor frontend apps",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "~5.7.2"
  }
}
