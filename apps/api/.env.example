PORT=3000

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/promentor?schema=public"

# Access JWT (short-lived) — default 900s = 15 minutes
JWT_SECRET="replace-with-a-strong-secret"
JWT_ACCESS_EXPIRES_IN_SECONDS=900

# Refresh token (opaque, DB) — cookie lifetime + DB row expiry
JWT_REFRESH_EXPIRES_DAYS=7

# CORS: frontend origin(s), comma-separated. Required for cookie auth across origins.
# Example: https://app.example.com  or  http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Cookie SameSite: lax (same-site dev) | none (cross-site SPA + API, needs HTTPS in prod)
COOKIE_SAME_SITE=lax