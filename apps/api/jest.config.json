{
  "rootDir": ".",
  "testEnvironment": "node",
  "moduleFileExtensions": ["js", "json", "ts"],
  "testMatch": [
    "<rootDir>/test/**/*.e2e-spec.ts",
    "<rootDir>/src/**/*.spec.ts"
  ],
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "tsconfig.e2e.json"
      }
    ]
  },
  "testPathIgnorePatterns": ["/node_modules/", "/dist/"]
}
