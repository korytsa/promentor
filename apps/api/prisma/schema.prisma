generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  REGULAR_USER
  MENTOR
}

enum ChatRoomType {
  PRIVATE @map("private")
  GROUP   @map("group")
}

enum CoachingTeamStatus {
  ACTIVE
  PENDING
}

enum CoachingTeamJoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MentorshipRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MentorBroadcastScope {
  TEAM
  INTERN
  BOARD
}

enum MentorBroadcastStatus {
  DELIVERED
  CANCELLED
}

enum MentorAvailabilityTier {
  HIGH
  MEDIUM
  LOW
}

enum SuggestionTargetScope {
  TEAM
  MENTOR
  BOARD
}

enum SuggestionPriority {
  HIGH
  MEDIUM
  LOW
}

enum TacticalBoardSurface {
  HOCKEY
  FOOTBALL
}

model User {
  id                           String                    @id @default(cuid())
  fullName                     String
  email                        String                    @unique
  passwordHash                 String
  role                         UserRole                  @default(REGULAR_USER)
  avatarUrl                    String?
  jobTitle                     String?
  about                        String?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
  refreshTokens                RefreshToken[]
  createdRooms                 ChatRoom[]                @relation("RoomCreator")
  roomMembers                  RoomMember[]
  sentMessages                 ChatMessage[]
  coachingTeamsCreated         CoachingTeam[]            @relation("CoachingTeamsCreated")
  coachingTeamMemberships      CoachingTeamMember[]      @relation("CoachingTeamMemberships")
  coachingTeamJoinRequests     CoachingTeamJoinRequest[] @relation("CoachingTeamJoinRequests")
  mentorAvailability           MentorAvailabilityTier?
  mentorWeeklySessions         Int                       @default(0)
  mentorshipRequestsAsMentor   MentorshipRequest[]       @relation("MentorshipMentor")
  mentorshipRequestsAsMentee   MentorshipRequest[]       @relation("MentorshipMentee")
  mentorBroadcastRequests      MentorBroadcastRequest[]
  mentorBroadcastMenteeTargets MentorBroadcastRequest[]  @relation("MentorBroadcastMenteeTarget")
  userBoardsOwned              UserBoard[]               @relation("UserBoardsOwned")
  userBoardMentorOf            UserBoard[]               @relation("UserBoardMentor")
  userSuggestionsSent          UserSuggestion[]          @relation("UserSuggestionsSent")
  userSuggestionsToMentor      UserSuggestion[]          @relation("SuggestionRecipientMentor")
  tacticalBoardsCreated        TacticalBoard[]           @relation("TacticalBoardsCreated")
}

model CoachingTeam {
  id                      String                    @id @default(cuid())
  name                    String
  status                  CoachingTeamStatus        @default(ACTIVE)
  createdById             String
  createdBy               User                      @relation("CoachingTeamsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  members                 CoachingTeamMember[]
  joinRequests            CoachingTeamJoinRequest[]
  mentorBroadcastRequests MentorBroadcastRequest[]
  userSuggestions         UserSuggestion[]
  tacticalBoards          TacticalBoard[]
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  @@index([createdById])
  @@map("coaching_teams")
}

model CoachingTeamJoinRequest {
  id          String                        @id @default(cuid())
  teamId      String
  team        CoachingTeam                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User                          @relation("CoachingTeamJoinRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  message     String?                       @db.Text
  status      CoachingTeamJoinRequestStatus @default(PENDING)
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt

  @@unique([teamId, requesterId])
  @@index([teamId, status])
  @@index([requesterId])
  @@map("coaching_team_join_requests")
}

model MentorshipRequest {
  id        String                  @id @default(cuid())
  mentorId  String
  mentor    User                    @relation("MentorshipMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  menteeId  String
  mentee    User                    @relation("MentorshipMentee", fields: [menteeId], references: [id], onDelete: Cascade)
  message   String?                 @db.Text
  status    MentorshipRequestStatus @default(PENDING)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@unique([mentorId, menteeId])
  @@index([mentorId, status])
  @@index([menteeId])
  @@map("mentorship_requests")
}

model MentorBroadcastRequest {
  id          String                @id @default(cuid())
  mentorId    String
  mentor      User                  @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  scope       MentorBroadcastScope
  teamId      String?
  team        CoachingTeam?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  menteeId    String?
  mentee      User?                 @relation("MentorBroadcastMenteeTarget", fields: [menteeId], references: [id], onDelete: SetNull)
  boardId     String?
  userBoard   UserBoard?            @relation(fields: [boardId], references: [id], onDelete: SetNull)
  targetLabel String
  contextLine String?               @db.Text
  body        String                @db.Text
  status      MentorBroadcastStatus @default(DELIVERED)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([mentorId, status, createdAt])
  @@index([menteeId])
  @@index([boardId])
  @@map("mentor_broadcast_requests")
}

model UserBoard {
  id                      String                   @id @default(cuid())
  name                    String
  ownerId                 String
  owner                   User                     @relation("UserBoardsOwned", fields: [ownerId], references: [id], onDelete: Cascade)
  mentorId                String
  mentor                  User                     @relation("UserBoardMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  suggestions             UserSuggestion[]
  mentorBroadcastRequests MentorBroadcastRequest[]

  @@index([ownerId])
  @@index([mentorId])
  @@map("user_boards")
}

model UserSuggestion {
  id                String                @id @default(cuid())
  senderId          String
  sender            User                  @relation("UserSuggestionsSent", fields: [senderId], references: [id], onDelete: Cascade)
  scope             SuggestionTargetScope
  recipientMentorId String
  recipientMentor   User                  @relation("SuggestionRecipientMentor", fields: [recipientMentorId], references: [id], onDelete: Cascade)
  teamId            String?
  team              CoachingTeam?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  boardId           String?
  userBoard         UserBoard?            @relation(fields: [boardId], references: [id], onDelete: SetNull)
  title             String
  detail            String
  priority          SuggestionPriority
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([senderId, createdAt])
  @@index([recipientMentorId, createdAt])
  @@index([boardId])
  @@map("user_suggestions")
}

model CoachingTeamMember {
  teamId   String
  userId   String
  joinedAt DateTime     @default(now())
  team     CoachingTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User         @relation("CoachingTeamMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
  @@map("coaching_team_members")
}

model TacticalBoard {
  id          String               @id @default(cuid())
  name        String
  teamId      String
  team        CoachingTeam         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User                 @relation("TacticalBoardsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  sessionDate DateTime             @db.Date
  boardType   TacticalBoardSurface
  objects     Json
  stroke      String
  strokeWidth Int
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([teamId, updatedAt])
  @@index([createdById])
  @@map("tactical_boards")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ChatRoom {
  id             String        @id @default(uuid()) @db.Uuid
  name           String?
  type           ChatRoomType
  privatePairKey String?       @unique
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  creator        User          @relation("RoomCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members        RoomMember[]
  messages       ChatMessage[]

  @@index([createdBy])
  @@map("chat_rooms")
}

model RoomMember {
  roomId     String    @db.Uuid
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId, joinedAt])
  @@index([roomId, joinedAt])
  @@map("room_members")
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @db.Uuid
  senderId  String
  message   String   @db.Text
  createdAt DateTime @default(now())
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}
